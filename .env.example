# Optional: Amadeus test credentials from https://developers.amadeus.com
# If unset, flights use historic fare/duration estimates (booking-window adjusted).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Optional: Navitia API key for SNCF train fallback
NAVITIA_API_KEY=

# Optional: enable Skyscanner Playwright scraping when Amadeus is not configured
USE_PLAYWRIGHT_FLIGHTS=false

# Use mock data only when live providers return nothing (off by default)
USE_MOCK_FALLBACK=false

# HAFAS mirror for European rail (default: Deutsche Bahn transport.rest)
HAFAS_BASE_URL=https://v6.db.transport.rest

# Parallel provider/API workers (default: min(8, CPU count))
SEARCH_WORKERS=

# Graph router: max flight airport pairs to check; skip intermodal below distance (km)
GRAPH_MAX_FLIGHT_LOOKUPS=12
SKIP_INTERMODAL_KM=250
